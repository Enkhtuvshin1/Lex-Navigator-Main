{
  "version": 3,
  "builds": [
    {
      "src": "legalidea-BE-main/legalidea-BE-main/app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "legalidea-FE-main/legalidea-FE-main/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/legalidea-BE-main/legalidea-BE-main/app/main.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/legalidea-FE-main/legalidea-FE-main/dist/$1"
    }
  ]
}
